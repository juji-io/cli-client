#!/usr/bin/env node

import dotenv from 'dotenv';
dotenv.config(); // load OPENAI_API_KEY from .env file
//import punycode from 'punycode';

import { request } from "http";
import OpenAI from "openai";
import { text } from "stream/consumers";
// https://github.com/mikeal/bent same author as deprecated request-promise
import bent from 'bent';
import util from 'util';
import color from 'colors';
import readline from 'readline';

const openai = new OpenAI({
    apiKey: process.env.OPENAI_API_KEY,
});

let debug = process.env.JUJI_DEBUG == "1";
console.log("debug=", debug, "typeof(debug)=", typeof (debug));

/*
 * parse command line argument
 */
import { Command } from 'commander';

const program = new Command();
//var program = require('commander');

program
    .description('Chat with a Juji bot. Does not require login.')
    .arguments('<url> <chatscript file>')
    .option('-f, --firstName <firstName>', 'first name', 'Guest')
    .option('-l, --lastName [lastName]', 'last name')
    .option('-e, --email [email]', 'email address');

program.on('--help', function () {
    console.log('')
    console.log('Example:');
    console.log('  juji chat -f Mary https://juji.ai/pre-chat/mycorp/3 test_chat_script');
});

program.parse(process.argv);

var args = program.args;

if (!args.length) {
    console.error('URL is required');
    program.outputHelp();
    process.exit(1);
}

const url = args[0];
const fn = args[1];

if (!program.firstName) {
    console.error('First name is required');
    program.outputHelp();
    process.exit(1);
}


/*
 * setup chat
 */

var chatInfo;
var ws;
var timeoutId;
var userResp, chatText;
var userRespIx = 0;
var sumRc = 0;
var startTime = Date.now();


// const bent = require('bent'),
//const util = require('util'),
//const color = require("colors"),
//    readline = require('readline'),
var rl = readline.createInterface({
    input: process.stdin,
    output: process.stdout
});

function console_out(msg) {
    if (msg != null) {
        process.stdout.clearLine();
        process.stdout.cursorTo(0);
        console.log(color.cyan(msg));
        rl.prompt(true);
    }
}

// take user input and send to server
const chatFormat = `
                mutation {
                    saveChatMessage(input: {
                        type: "normal"
                        pid: "%s"
                        text: "%s"
                    }) {
                        success
                    }
                }
                `;
rl.on('line', (line) => {
    ws.send(util.format(chatFormat, chatInfo.participationId, line));
});

rl.on('SIGINT', () => {
    rl.question('Are you sure you want to exit? ', (answer) => {
        if (answer.match(/^y(es)?$/i)) {
            rl.close();
            process.exit(sumRc);
        }
    });
});

import fs from 'fs';
let chatbot_name, user_name;

//
//
//
function loadChatscript() {
    var resp = Array();
    var chitchat = Array();
    try {
        const buf = fs.readFileSync(fn, 'utf8');
        var lines = buf.split("\n");
        console.log("nlines", lines.length);
        var achitchat = "";
        lines.forEach((line, i) => {
            // console.log(i, ": ", line);

            if (i == 0) {
                // Extract chatbot's name from the first transcript line
                let foo = line.match(/] (.*): /);
                chatbot_name = foo[1];
                console.log("chatbot_name", chatbot_name);
                // Split out chatbot text
                foo = line.split(/] .*: /, 3);
                console.log("foo=", foo);
                achitchat = foo[1];
            } else if (line.length > 0) {
                // parse chatbot responses
                let pos = line.indexOf(chatbot_name);

                if (pos > 0) {
                    let tokens = line.split(/] .*: /, 3);
                    achitchat = achitchat + "\n" + tokens[1];
                }
                // parse user response
                // pos = line.indexOf(chatbot_name); // look for chatbot prompt

                //var res = `*** ${pos} ${line}`;
                //console.log(line);
                // if (pos == -1 && line.length > 0) {
                else {

                    // save the concatenated chatbot texts
                    chitchat.push(achitchat);
                    achitchat = "";

                    // parse user response
                    let ress = line.split(/] .*: /, 3);
                    let foo = line.match(/] (.*): /); // extract user name
                    let bar = line.match(/:text "(.*)"/); // if exist, extract :text value [{:type "Action", :gid "question_30", :question "question_30", :value 0, :text "Economy"}]
                    if (bar != undefined) {
                        ress[1] = bar[1].trim();
                    }
                    console.log("bar ", bar)
                    console.log("--- res", ress);
                    console.log("=== foo", foo);
                    user_name = foo[1];

                    let res;
                    if (ress.length > 0) {
                        res = `${user_name}: ${ress[1]}`;
                    }
                    //console.log(res);
                    resp.push(ress[1])
                }
            }

        })

        return [chitchat, resp];

    } catch (err) {
        console.error(err);
    }
}

const system_prompt = "You are given a Context paragraph and two AI response paragraphs. If the two response paragraph express the same intent, then return a 0, otherwise a 1";
const user_prompt = "[Context] $CONTEXT\n\n[Response 1] $P1\n\n[Response 2] $P2";
let context = "My parents came to the U.S, 30 years ago and attended colleges here. They met and got married. My grandma owns a Chinese restaurant and my parents went into this family business. I am the middle child of three children. I have an older brother who is a senior at Princeton University, and a younger brother who is in middle school.";
let p1 = "Your family sounds accomplished and close-knit, with a strong entrepreneurial spirit. It's great to hear about your brothers' achievements too.";
let p2 = "Your family's journey and achievements are impressive. It sounds like a supportive and ambitious environment to grow up in.";

var request_messages_template = {
    model: "gpt-4o",
    messages: [
        {
            "role": "system",
            "content": [
                {
                    "type": "text",
                    "text": system_prompt
                }
            ]
        },
        {
            "role": "user",
            "content": [
                {
                    "type": "text",
                    "text": ""
                }
            ]
        }
    ],
    response_format: {
        "type": "text"
    },
    temperature: 1,
    max_completion_tokens: 2048,
    top_p: 1,
    frequency_penalty: 0,
    presence_penalty: 0
}

//
//
//
async function compare_intent(context1, para1, para2) {

    if (debug) {
        console.log(`compare_intent()\ncontext=${context1}\nP1=${para1}\nP2=${para2}\n`);
    }
    if (para1 == undefined || para2 == undefined) {
        return;
    }
    let request_messages = structuredClone(request_messages_template);

    let text1 = user_prompt;
    text1 = text1.replace("$CONTEXT", context1);
    text1 = text1.replace("$P1", para1);
    text1 = text1.replace("$P2", para2);
    //console.log(text1);

    request_messages.messages[1].content = text1;

    // a new thread blocks here waiting for response. Calling thread continues.
    const response = await openai.chat.completions.create(request_messages);
    //   .then(resp => {
    //   //console.log(resp);
    //   let resultstr = resp.choices[0].message.content;
    //   console.log("resultstr=", resultstr);
    //   if (resultstr == "1") { // not equal
    //     rc = 1;
    //   }
    // });

    // process returned response from openai
    // response= {
    // id: 'chatcmpl-AstgJSY1tsAxpQ6j8uYF1NaPzd12N',
    //   object: 'chat.completion',
    //     created: 1737647115,
    //       model: 'gpt-4o-2024-08-06',
    //         choices: [
    //           {
    //             index: 0,
    //             message: [Object],
    //             logprobs: null,
    //             finish_reason: 'stop'
    //           }
    //         ],
    // ...}
    // console.log("await response=", response);
    // .message.content is a string value of 1 (not equivalent) or 0 (equivalent)
    let resultstr = response.choices[0].message.content;
    // console.log("resultstr=", resultstr);
    let rc = 0;
    if (resultstr == "1") { // not equivalent
        rc = 1;
    }
    let testResult = "PASS";
    if (rc == 1) {
        testResult = "FAILED";
    }
    console.log("[AI synthesized] intention comparison:", testResult);
    if (rc > 0) {
        sumRc = rc;
    }
    //process.exitCode = rc;
}

const AI_synthesized = "[AI synthesized]";
import WebSocket from 'isomorphic-ws';
import FormData from 'form-data';

async function startChat() {

    //
    // step 1: obtain chat information
    //
    startTime = Date.now();
    // var FormData = require('form-data');
    var form = new FormData();
    form.append('firstName', program.firstName);

    const postJSON = bent('POST', 'string', { 'Content-Type': 'multipart/form-data' });
    //const postJSON = bent('POST', 'buffer', { 'Content-Type': 'multipart/form-data'});

    const response = await postJSON(url, form, form.getHeaders());

    // console.log(response);
    // Example chatInfo =
    // {"chatUrl":"https://juji.ai/chat/67460ae2-a468-4169-a95d-92e4a8aba110",
    //  "participationId":"67460ae2-a468-4169-a95d-92e4a8aba110",
    //  "websocketUrl":"wss://juji.ai/api/v1/ws"}
    chatInfo = JSON.parse(response);

    //
    // step 2: setup WebSocket connection
    //

    //const WebSocket = require('isomorphic-ws');
    ws = new WebSocket(chatInfo.websocketUrl);

    //
    // step 3: subscribe to incoming chat messages
    //
    ws.onopen = function () {

        const subFormat = `
        subscription {
            chat(input: {
                participationId: "%s"
            }) {
                role
                text
                type
                endOfMessage
                display{
                    type
                    data{
                        type
                        questions{
                            heading
                            kind
                            wording
                            choices{
                                text
                                value
                                other
                            }
                        }
                    }
                }
                quickReply{
                    type
                    text
                    options
                    reminder
                }
            }
        }`
        ws.send(util.format(subFormat, chatInfo.participationId));
    };

    let chattext;

    //
    // step 4: receive chat messages
    //
    ws.onmessage = function (incoming) {

        var data = JSON.parse(incoming.data);
        //console.log(data);

        // only deal with chat messages, ignore other message types
        if ('data' in data && 'chat' in data.data) {
            // clear the timeout to restart the clock again


            var message = data.data.chat;
            // console.log(message.display)

            // only print out REP's chat messages
            if (message.role == 'rep') {
                //console.log("Clear Timeout...");
                clearTimeout(timeoutId);
                //console.log("Clear timeoutId:", timeoutId);

                // {
                //     data: {
                //         chat: {
                //             role: 'rep',
                //             text: null,
                //             type: 'flowinfo',
                //             endOfMessage: true,
                //             display: null,
                //             quickReply: null
                //         }
                //     }
                // }
                if (message.type == 'flowinfo') {
                    if (message.endOfMessage) {
                        let end = Date.now();
                        console.log("endOfMessage: true");
                        let elapsedTime = end - startTime;
                        console.log("ElapsedTime=", elapsedTime);
                        //console.log("GOT", chattext);
                        let p1 = chattext; // current [AI synthesized] paragraph
                        chattext = ""; // reset chattext
                        //console.log("userRespIx", userRespIx);
                        let rtext = chatText[userRespIx]; // chatscript AI Synthesized text
                        //console.log(`chatText[${userRespIx}] ${rtext}`);
                        let pos, rchat, p2;
                        if (rtext != undefined) {
                            if ((pos = rtext.indexOf(AI_synthesized)) > 0) {
                                rchat = rtext.substring(0, pos).trim();
                            }
                            p2 = rchat; // chatscript [AI synthensized] paragraph
                        }
                        //console.log("EXPECT rchat=", rchat, "\nrtext=", rtext, "\n------------");

                        let line = userResp[userRespIx];
                        let ix = 0;
                        if (line != undefined) {
                            ws.send(util.format(chatFormat, chatInfo.participationId, line));
                            console.log(`User response[${userRespIx}] ${line}`);
                            ix = userRespIx + 1;
                        }
                        startTime = Date.now();

                        let ctext;
                        if (userRespIx > 0 && userRespIx < chatText.length) {
                            ctext = userResp[userRespIx - 1]; // user response from previous offset
                        }
                        // do intent comparison
                        if (p1 != undefined && p2 != undefined && context != undefined) {
                            compare_intent(ctext, p1, p2);
                        } else {
                            console.log("Nothing to compare @", userRespIx);
                        }
                        userRespIx = ix;
                        if (ix >= userResp.length) {
                            process.exit(sumRc);  // exit after ran out userResp
                        }

                    }
                } else if (message.type == 'normal') {

                    console_out(message.text);
                    if (message.text != null && message.text.length > 0) {
                        //chattext = chattext + "\n" + message.text;
                        let pos;
                        if ((pos = message.text.indexOf(AI_synthesized)) > 0) {
                            chattext = message.text.substring(0, pos).trim();
                            //console.log(`message.text=${message.text}\npos=${pos} ${chattext}`);
                        }
                    }

                    if (message.display) {
                        //console.log(message.display)
                        message.display.data.questions.forEach(function (value, index, array) {
                            console_out(value.kind + ' GUI question: ' + value.heading);
                            if (value.choices) {
                                value.choices.forEach(function (c, i, a) {
                                    console_out('[Choice] text: ' + c.text + '; value: ' + c.value);
                                })
                            }

                        })
                    }
                    if (message.quickReply) {
                        console.log("quickReply: ", message.quickReply)
                        let line = userResp[userRespIx];
                        if (line != undefined) {
                            ws.send(util.format(chatFormat, chatInfo.participationId, line));
                            console.log(`User response[${userRespIx}] ${line}`);
                            userRespIx++;
                        }
                    }
                    //console.log("SetTimeOut()...");
                    timeoutId = setTimeout(function () {
                        let end = Date.now();
                        console.log("***TIMEOUT*** 60 seconds GOT", chattext);
                        chattext = "";
                        console.log("EXPECT", chatText[userRespIx], "\n------------");
                        // FIXME: skip going to openai to compare intent
                        let line = userResp[userRespIx];
                        if (line != undefined) {
                            ws.send(util.format(chatFormat, chatInfo.participationId, line));
                            console.log(`User response[${userRespIx}] ${line}`);
                            userRespIx++;
                        }
                        let elapsedTime = end - startTime;
                        console.log("Timeout elapsed time=", elapsedTime);
                        startTime = Date.now();

                    }, 60000); // 60 seconds timeout
                } else if (message.type == 'user-joined') {
                    console.log('');
                    console.log(color.blue('=== Welcome to Juji Bot ==='));
                    console.log('');
                }
            }

        }
    };

}

function main() {
    [chatText, userResp] = loadChatscript();
    if (debug) {
        chatText.forEach((r, i) => {
            console.log(i, r);
        })
        userResp.forEach((r, i) => {
            console.log(i, r);
        })
    }
    startChat().catch(error => console.error(error))
}

main();
